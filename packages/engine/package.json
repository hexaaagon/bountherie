{
  "name": "@bountherie/engine",
  "version": "0.1.0",
  "description": "Client-side image processing engine for boundary operations",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./load": "./src/load.ts",
    "./process": "./src/process.ts",
    "./export": "./src/export.ts",
    "./widget": "./src/widget.ts",
    "./types": "./src/types.ts",
    "./resize": "./src/resize.ts",
    "./gif": "./src/gif.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
