{
  "name": "bountherie",
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/bun": "^1.3.14",
    "turbo": "^2.10.3",
    "typescript": "5.9.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "biome check --write .",
    "lint:fix": "biome check --write .",
    "lint:check": "biome check .",
    "check-types": "turbo run check-types"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
