---
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils"
---

<div class="absolute top-4 right-8">
  <theme-toggle data-button-class={cn(buttonVariants({ variant: "outline", size: "sm" }), "h-8 rounded-full shadow-xl border border-foreground/20 has-[>svg]:px-6 backdrop-blur-xs")}></theme-toggle>
</div>

<script is:inline>
  if (!customElements.get("theme-toggle")) {
    customElements.define(
      "theme-toggle",
      class extends HTMLElement {
        connectedCallback() {
          const btnClass = this.getAttribute("data-button-class");
          this.innerHTML = `
            <button
              type="button"
              class="${btnClass}"
              aria-label="Toggle theme"
            >
              <svg class="size-4 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="4"/>
                <path d="M12 2v2"/>
                <path d="M12 20v2"/>
                <path d="m4.93 4.93 1.41 1.41"/>
                <path d="m17.66 17.66 1.41 1.41"/>
                <path d="M2 12h2"/>
                <path d="M20 12h2"/>
                <path d="m6.34 17.66-1.41 1.41"/>
                <path d="m19.07 4.93-1.41 1.41"/>
              </svg>
              <svg class="size-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
            </button>
          `;
          this.querySelector("button").onclick = () => {
            const current = theme.getTheme();
            const resolved = current === "auto" ? theme.getSystemTheme() : current;
            theme.setTheme(resolved === "dark" ? "light" : "dark");
          };
          this.setAttribute("aria-label", "Toggle theme");
        }
      }
    );
  }
</script>
